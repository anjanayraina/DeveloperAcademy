# ─── LLM Providers ───────────────────────────────────────────────────────────
# Set DEFAULT_LLM to "openclaw", "hermes", "claude", or "mock"
DEFAULT_LLM=openclaw

# Vercel AI Mentor API
MENTOR_API_URL=https://frontend-v2-eta-red.vercel.app/api/agents/mentors/ask
MENTOR_BEARER_TOKEN=60d6b55053548bd64ce97ebaba3ae09b5574f744655b3a44ef254158eda41899

# Anthropic Claude API key
CLAUDE_API_KEY=sk-ant-your-key-here

# Hermes (OpenAI-compatible) endpoint
HERMES_API_URL=http://localhost:11434/v1
HERMES_MODEL=hermes-3-llama-3.1-8b

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=["http://localhost:5173"]
MONGODB_URI=your-mongodb-connection-string

# ─── GitHub OAuth ────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:5173

# ─── JWT Auth ────────────────────────────────────────────────────────────────
SECRET_KEY=your-jwt-signing-secret-key-here
JWT_ALGORITHM=HS256
