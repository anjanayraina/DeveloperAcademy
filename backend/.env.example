# ─── LLM Providers ───────────────────────────────────────────────────────────
# Set DEFAULT_LLM to "claude" or "hermes"
DEFAULT_LLM=mock

# Anthropic Claude API key
CLAUDE_API_KEY=sk-ant-your-key-here

# Hermes (OpenAI-compatible) endpoint
HERMES_API_URL=http://localhost:11434/v1
HERMES_MODEL=hermes-3-llama-3.1-8b

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:5173
